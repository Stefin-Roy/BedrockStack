{
  "arch": "riscv64",
  "code-model": "medium",
  "cpu": "generic-rv64",
  "crt-objects-fallback": "false",
  "data-layout": "e-m:e-p:64:64-i64:64-i128:128-n64-S128",
  "disable-redzone": true,
  "features": "+m,+a,+c",
  "linker": "rust-lld",
  "linker-flavor": "gnu-lld",
  "llvm-target": "riscv64-unknown-none-elf",
  "max-atomic-width": 64,
  "metadata": {
    "description": "BedrockOS bare-metal riscv64 kernel",
    "host_tools": false,
    "std": false,
    "tier": 2
  },
  "panic-strategy": "abort",
  "plt-by-default": false,
  "relro-level": "none",
  "rustc-abi": "softfloat",
  "stack-probes": {
    "kind": "inline"
  },
  "supported-sanitizers": [],
  "target-pointer-width": 64
}
